{
  "id": "study3_cohort_vhir",
  "resourceType": "PopulationPipeline",
  "url": "https://datatools4heart.eu/cohorts/study3-vhir",
  "name": "study3_cohort_vhir",
  "title": "Adult Cardiology Outpatient Cohort with Heart Failure Diagnosis (Any Time)",
  "description": "This cohort includes cardiology department visits of adult patients diagnosed with heart failure at any time.",
  "version": "1.2",
  "date": "2026-06-19",
  "status": "active",
  "publisher": "DataTools4Heart/AI4HF Team (SRDC Corp.)",
  "interface": "fhir",
  "supportedVersions": [
    "R5"
  ],
  "entry": [
    {
      "name": "patientEncounter",
      "description": "Captures cardiology outpatient encounters (ambulatory class) for patients.",
      "resourceType": "Encounter",
      "query": "?service-type=http://snomed.info/sct|394579002&class=AMB",
      "entityLink": [
        {
          "entity": "pid",
          "entityType": "Patient",
          "searchParam": "patient",
          "path": "subject.reference"
        }
      ],
      "eventTime": "Encounter.actualPeriod.start",
      "exitTime": "(Encounter.actualPeriod.end.toDate() | (Encounter.actualPeriod.start.substring(0, 10).toDate() + 1 days)).first()"
    }
  ],
  "eligibility": [
    {
      "name": "adults",
      "description": "Filters adults patients.",
      "criteria": [
        {
          "name": "adult",
          "description": "Excludes patients younger than 18 years at the time of encounter.",
          "resourceType": "Patient",
          "category": "exclusion",
          "entityLink": [
            {
              "entity": "pid",
              "entityType": "Patient",
              "searchParam": "_id",
              "path": "id"
            }
          ],
          "timeConstraint": {
            "path": "birthDate.toDate()",
            "start": "(%eligibilityEventTime - 18 years)"
          }
        }
      ]
    }
  ]
}
